                <ReactiveSequence _while="current_role == 'goal_keeper'">
                    <GoToPose target_pos_x="-4.0" target_pos_y="0.0" target_pos_theta="0.0" turn_threshold="0.5" stop_threshold="0.1" v_limit="0.6" />
                </ReactiveSequence>
                <ReactiveSequence _while="current_role == 'lead_striker'">
                    <CalcPassDir/>
                    <SetpieceDecide decision_out="{decision}" decision_in="{decision}" decide_type="Pass"/>
                    <SetpieceChase _while="decision=='chase'" chase_type="Pass"/>
                    <SetpieceAdjust _while="decision=='adjust'" adjust_type="Pass"/>
                    <SetVelocity _while="decision=='stop'" x="0.0" y="0.0" theta="0.0"/>
