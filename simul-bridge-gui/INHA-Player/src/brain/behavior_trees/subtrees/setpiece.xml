                <ReactiveSequence _while="current_role == 'sub_striker'">
                    <OfftheballPosition/>
                </ReactiveSequence>
            </ReactiveSequence>

            <ReactiveSequence _while="!gc_is_our_secondary_state">
                <Script code="is_race=false; is_possession=false" />
                <SetPieceRoleManager current_role="{current_role}" />
                <SubTree ID="CamFindAndTrackBall" _autoremap="true" />
                <ReactiveSequence _while="current_role == 'goal_keeper'">
                    <GoToPose target_pos_x="-4.0" target_pos_y="0.0" target_pos_theta="0.0" turn_threshold="0.5" stop_threshold="0.1" v_limit="0.6" />
                </ReactiveSequence>
                <ReactiveSequence _while="current_role == 'lead_defender'">
                    <CalcKickInPose1 block_target_x="{block_x}" block_target_y="{block_y}" block_target_theta="{block_theta}"/>
                    <GoToPose target_pos_x="{block_x}" target_pos_y="{block_y}" target_pos_theta="{block_theta}" turn_threshold="0.5" stop_threshold="0.1" v_limit="0.6" />
                </ReactiveSequence>
                <ReactiveSequence _while="current_role == 'sub_defender'">
