                    <GoToPose target_pos_x="{block_x}" target_pos_y="{block_y}" target_pos_theta="{block_theta}" turn_threshold="0.5" stop_threshold="0.1" v_limit="0.6" />
                </ReactiveSequence>
            </ReactiveSequence>
        </ReactiveSequence>

        <!-- 9. Free_Kick (default) -->
        <ReactiveSequence _while="gc_game_secondary_state=='FREE_KICK' &amp;&amp; gc_game_secondary_state_info=='GET_READY'" name="Free_Kick">
            <ReactiveSequence _while="gc_is_our_secondary_state">
                <SubTree ID="CamFindAndTrackBall" _autoremap="true" />
                <SetVelocity x="0.0" y="0.0" theta="0.0" />
            </ReactiveSequence>

            <ReactiveSequence _while="!gc_is_our_secondary_state">
                <SubTree ID="CamFindAndTrackBall" _autoremap="true" />
                <SetVelocity x="0.0" y="0.0" theta="0.0" />
            </ReactiveSequence>
        </ReactiveSequence>

        <!-- SET -->
        <ReactiveSequence _while="gc_game_secondary_state_info=='SET'">
            <SetVelocity x="0.0" y="0.0" theta="0.0" />
            <SubTree ID="CamFindAndTrackBall" _autoremap="true" /> 
        </ReactiveSequence>

    </ReactiveSequence>
  </BehaviorTree>
</root>